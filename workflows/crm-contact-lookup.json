    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { success: false, error: 'CRM API request failed: ' + ($json.error || $json.message || 'Unknown error'), status_code: $json.statusCode || null } }}",
        "options": {
          "responseCode": 502
        }
      },
      "id": "a1b2c3d4-1111-4000-8000-000000000011",
      "name": "Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 440]
    },
    {
      "parameters": {
        "jsCode": "// Format CRM response into structured output for OpenClaw\nconst crmData = $input.first().json;\n\n// Handle empty/not-found responses\nif (!crmData || (Array.isArray(crmData) && crmData.length === 0)) {\n  return [{\n    json: {\n      success: true,\n      found: false,\n      contact: null,\n      message: 'No contact found matching the search criteria'\n    }\n  }];\n}\n\nconst contact = Array.isArray(crmData) ? crmData[0] : crmData;\n\nreturn [{\n  json: {\n    success: true,\n    found: true,\n    contact: {\n      id: contact.id || null,\n      first_name: contact.first_name || contact.firstName || null,\n      last_name: contact.last_name || contact.lastName || null,\n      email: contact.email || null,\n      phone: contact.phone || null,\n      status: contact.status || null,\n      created_at: contact.created_at || contact.createdAt || null,\n      tags: contact.tags || [],\n      custom_fields: contact.custom_fields || {}\n    },\n    source: 'crm',\n    retrieved_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "a1b2c3d4-1111-4000-8000-000000000003",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "a1b2c3d4-1111-4000-8000-000000000004",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1140, 200]
    },
    {
      "parameters": {
        "content": "## MCP: CRM Contact Lookup\n\n**Purpose:** Replace LLM doing CRM lookups via OpenClaw MCP.\n\n**Token savings:** ~5,000 tokens per call\n\n**Flow:** Webhook (POST /mcp/crm-lookup) -> CRM API -> Error Check -> Format -> Respond\n\n**Expected payload:**\n```json\n{\n  \"email\": \"client@example.com\",\n  \"phone\": \"+14075551234\"\n}\n```\n\n**Setup:**\n1. Replace CRM API URL with your Lawmatics/CRM endpoint\n2. Set `CRM_API_KEY` env var (or better: use n8n credentials for production)\n3. Activate workflow\n\n**Note:** For production, replace the env var Authorization header with a proper n8n HTTP credential. Env vars are for quick testing only.",
        "height": 420,
        "width": 340
      },
      "id": "a1b2c3d4-1111-4000-8000-000000000005",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [240, -120]
    }
  ],
