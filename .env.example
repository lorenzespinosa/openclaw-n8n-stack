# ═══════════════════════════════════════════════════════════
# OpenClaw + n8n Stack — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# Generate random strings: openssl rand -hex 32

# ── PostgreSQL ──
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_32
POSTGRES_DB=n8n

# ── n8n ──
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=CHANGE_ME_USE_openssl_rand_hex_32
N8N_MCP_SERVER_ENABLED=true

# n8n Authentication (REQUIRED — do not disable)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_16

# n8n API Key (needed for init-workflows.sh)
# Generate in n8n: Settings → API → Create API Key
N8N_API_KEY=

# ── OpenClaw ──
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_USE_openssl_rand_hex_32

# AI Provider (pick one or both)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
ANTHROPIC_API_KEY=

# Slack (optional — leave empty to skip Slack integration)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── General ──
TZ=America/New_York
