# ═══════════════════════════════════════════════════════════
# OpenClaw + n8n Stack — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.

# ── PostgreSQL ──
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=n8n

# ── n8n ──
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=CHANGE_ME_random_32_char_string
N8N_MCP_SERVER_ENABLED=true

# ── OpenClaw ──
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_random_token_here

# AI Provider (pick one or both)
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
ANTHROPIC_API_KEY=

# Slack (optional — leave empty to skip Slack)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── General ──
TZ=America/New_York
